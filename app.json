{
  "expo": {
    "name": "FormCritic",
    "slug": "formcritic",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "formcriticapp",
    "userInterfaceStyle": "automatic",
    "description": "AI-powered exercise form analysis using Claude Vision API",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "icon": "./assets/expo.icon",
      "supportsTabletOS": false,
      "infoPlist": {
        "NSCameraUsageDescription": "FormCritic needs camera access to record your exercises",
        "NSPhotoLibraryUsageDescription": "FormCritic needs photo library access to save videos",
        "NSMicrophoneUsageDescription": "FormCritic needs microphone access to record audio during exercises"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "fe2859a2-ab03-4603-b916-93c6c98dcd0b"
      }
    }
  }
}
